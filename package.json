{
  "name": "delivest",
  "version": "1.0.0",
  "private": true,
  "description": "Monorepo for Delivest: NestJS + Vue 3",
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "build": "pnpm -r run build",
    "build:types": "pnpm --filter @delivest/types build",
    "build:common": "pnpm --filter @delivest/common build",
    "lint": "pnpm -r run lint",
    "format:check": "prettier --check .",
    "format:fix": "prettier --write .",
    "test": "pnpm -r run test",
    "api:dev": "pnpm --filter delivest-api dev",
    "web:dev": "pnpm --filter delivest-web dev",
    "prisma:generate": "pnpm --filter delivest-api prisma:generate",
    "prisma:push": "pnpm --filter delivest-api prisma:push",
    "ci": "pnpm audit --production || true && pnpm format:check && pnpm lint && pnpm test"
  },
  "devDependencies": {
    "@vue/eslint-config-typescript": "^14.7.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-oxlint": "~1.50.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-vue": "~10.8.0",
    "globals": "^16.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.20.0"
  }
}
