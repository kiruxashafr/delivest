generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Branch {
  id    String @id @default(uuid())
  alias String @unique
  name  String

  info BranchInfo?

  @@map("branches")
}

model BranchInfo {
  id          String  @id @default(uuid())
  description String? @db.Text
  address     String

  branch   Branch @relation(fields: [branchId], references: [id])
  branchId String @unique @map("branch_id")

  @@map("branch_info")
}
